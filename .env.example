# ============================================================
# FOREX AI — Environment Configuration Template
# ============================================================
# Copy this file to `.env` and fill in your actual credentials:
#   cp .env.example .env
#
# NEVER commit the real `.env` file — it contains secrets.
# ============================================================

# ── EXECUTION MODE ────────────────────────────────────────────
# mt5_demo  → Real MT5 demo account (requires MT5 terminal running on Windows)
# paper     → Local simulation (no broker)
EXECUTION_MODE=mt5_demo

# ── APPROVAL MODE ─────────────────────────────────────────────
# 1 = analysis only (no trades)
# 2 = supervised (human approves each trade)
# 3 = autonomous (no human gate — default for testing)
APPROVAL_MODE=3

# ── TEST MODE (Day 81+) ──────────────────────────────────────
# When true: relaxes all safety gates so trades actually execute on MT5 demo.
#  - Confidence threshold lowered to 10 (instead of 60)
#  - Session quality check becomes warning (instead of block)
#  - ConfidenceEngine auto-skip disabled
#  - ConfidenceEngine WAIT threshold lowered to 10 (instead of 25)
# WARNING: only use this on MT5 DEMO accounts, never on live accounts.
TEST_MODE=true

# ── TRADING MODE (Day 81+) ────────────────────────────────────
# SAFE        — high-confidence-only (80%+), all confirmations required
# AUTONOMOUS  — balanced (60%+), trades per ApprovalMode (default)
# When TEST_MODE=true, this is ignored and threshold drops to 10%.
TRADING_MODE=AUTONOMOUS

# ── ABSOLUTE_SAFETY (Day 81+) ─────────────────────────────────
# Independent kill-switch — ALWAYS active regardless of TRADING_MODE.
# Blocks trades when:
#   - broker disconnect / no tick data
#   - spread > 5x normal (news just hit)
#   - market closed (spread = 0)
# Set to false ONLY for paper trading or stress testing.
ABSOLUTE_SAFETY=true

# ── TRADE FREQUENCY (Day 84+) ────────────────────────────────
# Hard bounds on daily trade count.
# MIN — if not met by mid-day, adaptive threshold lowers (more permissive)
# MAX — hard cap; no new trades once hit (avoids over-trading)
MIN_DAILY_TRADES=3
MAX_DAILY_TRADES=15

# ── USE SCANNER ───────────────────────────────────────────────
# true  → scan 28-pair universe each cycle, pick top opportunities
# false → trade fixed SYMBOLS list from config.py
USE_SCANNER=false

# ── MT5 BROKER CREDENTIALS ────────────────────────────────────
# Get these from your MT5 demo account. The MT5 Windows terminal
# MUST be running and logged in to the same account before you
# start this Python system.
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=ICMarketsSC-Demo
# Optional: full path to terminal.exe (only if MT5 isn't auto-detected)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# Optional: investor (read-only) password
# MT5_INVESTOR=

# ── TELEGRAM ALERTS (optional) ────────────────────────────────
ENABLE_TELEGRAM=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── LLM PROVIDERS (free tier — Groq primary, Gemini fallback) ─
# Groq free tier has strict rate limits (~30 req/min, 14k req/day).
# To avoid "429 Too Many Requests" mid-trade, register 6 separate
# Groq accounts and put one key in each slot below. The system's
# LLMKeyManager auto-rotates: if key #1 hits rate limit, it's
# disabled for 30s and the next call uses key #2, and so on.
#
# Get your free Groq keys from: https://console.groq.com/keys
# (Log out + sign up with a different email to get additional keys.)
#
# PRIMARY KEY (required)
GROQ_API_KEY_1=
# EXTRA KEYS — used automatically when primary hits rate limit
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
# Backwards-compat alias (optional — same as GROQ_API_KEY_1)
# GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini fallback (used when ALL Groq keys are rate-limited)
# Get your free Gemini key from: https://aistudio.google.com/app/apikey
# Multiple keys supported: GEMINI_API_KEY_1, GEMINI_API_KEY_2, ...
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.0-flash

# HuggingFace token (optional — for sentence-transformers downloads)
HF_TOKEN=

# ── OPTIONAL EXTERNAL DATA APIs ───────────────────────────────
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_API_KEY=
FRED_API_KEY=

# ── AUTOMATED RETRAINING ──────────────────────────────────────
RETRAINING_INTERVAL=24
PERFORMANCE_THRESHOLD=0.55
MIN_TRAINING_SAMPLES=100

# ── LOGGING ───────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── WEBHOOK (TradingView alerts) ──────────────────────────────
# Generate your own with: python -c "import secrets; print(secrets.token_hex(32))"
# TradingView alert URL must include ?secret=<this_value>
WEBHOOK_SECRET=replace_with_your_own_random_64_char_hex_string
WEBHOOK_PORT=5000

# ── SMTP / EMAIL (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_RECIPIENTS=
ALERT_WEBHOOK_URL=

# ── Execution / Day 37 Integration (core/trader.py, main.py) ─
# "paper"    = simulated PaperTrader (default, safe, no real/demo orders).
# "mt5_demo" = real MT5 demo account (needs MT5_* below + a broker/mt5_executor.py
#              implementation — not built yet, ExecutionRouter will stop at the
#              safety-check stage and log PENDING_EXECUTOR until that exists).
EXECUTION_MODE=paper

# Pull each cycle's Top-N pairs from scanner/market_scanner.py instead of the
# static SYMBOLS list below. Requires an MT5 market-data adapter
# (broker/market_data_manager.py) to actually rank pairs — until that's
# wired in, this safely no-ops back to SYMBOLS even if set to true.
USE_SCANNER=false

# 1 = analysis only (AI watches, never trades)
# 2 = supervised (AI suggests, a human must approve() each trade)
# 3 = autonomous (default — matches pre-Day-37 behavior, no human gate)
# NOTE: once set, the running mode persists to memory/approval_mode.json
# and overrides this value on restart until changed via approval.set_mode().
APPROVAL_MODE=3

# ── MT5 Demo Broker (only required if EXECUTION_MODE=mt5_demo) ──
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# ── Webhook (server/webhook_server.py — TradingView "Webhook URL" alerts) ──
WEBHOOK_SECRET=
WEBHOOK_PORT=5000

# ── Loop / Capital Settings (config.py defaults, overridable here) ──
PAPER_BALANCE=10000
LOOP_INTERVAL_SEC=60
BACKUP_INTERVAL_MIN=30
RECOVERY_COOLDOWN_MIN=5